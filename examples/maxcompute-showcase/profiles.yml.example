# Copy this file to `profiles.yml` (same directory) and fill in your project.
# `profiles.yml` is git-ignored so credentials never get committed.
#
# Auth uses environment variables — set them in your shell before running dbt:
#   export ODPS_ACCESS_ID=...
#   export ODPS_SECRET_ACCESS_KEY=...
#
# For an authoritative list of MaxCompute project endpoints see
# https://www.alibabacloud.com/help/en/maxcompute/user-guide/endpoints

maxcompute_showcase:
  target: dev
  outputs:

    # ── Standard offline mode ──────────────────────────────────────────
    dev:
      type: maxcompute
      project: your_maxcompute_project       # required
      schema: default                        # default schema inside the project
      endpoint: http://service.cn-hangzhou.maxcompute.aliyun.com/api
      auth_type: aliyun_access_key
      access_id: "{{ env_var('ODPS_ACCESS_ID') }}"
      secret_access_key: "{{ env_var('ODPS_SECRET_ACCESS_KEY') }}"

    # ── MaxQA (MCQA V2) mode ──────────────────────────────────────────
    # Submits SQL through the MaxQA interactive endpoint for faster
    # execution. DDL/DML that MaxQA cannot handle is automatically
    # fallen back to offline by the server (when maxqa_fallback is true).
    dev_maxqa:
      type: maxcompute
      project: your_maxcompute_project
      schema: default
      endpoint: http://service.cn-hangzhou.maxcompute.aliyun.com/api
      auth_type: aliyun_access_key
      access_id: "{{ env_var('ODPS_ACCESS_ID') }}"
      secret_access_key: "{{ env_var('ODPS_SECRET_ACCESS_KEY') }}"

      execution_mode: maxqa                  # enable MaxQA
      quota_name: your_interactive_quota     # optional — interactive quota group
      # maxqa_fallback: true                 # default: true (server-side fallback)
      # maxqa_fallback_quota: your_offline_q # optional — offline quota for fallback
